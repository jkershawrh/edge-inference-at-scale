# BitNet llama-server — native 1.58-bit ternary inference on CPU
# Patched from edge-ai-cpu-inference to relax torch version pin

FROM registry.access.redhat.com/ubi9/ubi:9.4 AS builder

RUN dnf install -y clang cmake make git python3 python3-pip && \
    dnf clean all

WORKDIR /build
RUN git clone --recursive https://github.com/microsoft/BitNet.git

WORKDIR /build/BitNet

# Only install what we actually need for the build (gguf conversion + cmake)
# Skip the full requirements.txt — it pins torch==2.11.0 which doesn't exist
RUN pip3 install numpy sentencepiece gguf "protobuf<5" "huggingface_hub[cli]" tokenizers safetensors tqdm pyyaml filelock regex requests packaging

# Pre-patch const-correctness bug in ternary kernel
RUN find . -name "*.cpp" -o -name "*.h" | \
    xargs grep -rl "int8_t \* y_col" 2>/dev/null | \
    xargs sed -i 's/int8_t \* y_col/const int8_t * y_col/g' 2>/dev/null; \
    echo "const patch applied"

# Build llama-server
# Use BitNet's own setup_env.py which handles cmake flags correctly
# It builds llama-server as part of the full build
RUN pip3 install torch --index-url https://download.pytorch.org/whl/cpu 2>&1 && \
    python3 setup_env.py --hf-repo microsoft/BitNet-b1.58-2B-4T -q i2_s --build-only 2>&1 || \
    (cmake -B build -DBITNET_X86_TL2=OFF \
        -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ \
        -DLLAMA_FATAL_WARNINGS=OFF \
        -DLLAMA_BUILD_EXAMPLES=ON -DLLAMA_BUILD_SERVER=ON 2>&1 && \
     cmake --build build --config Release -j4 2>&1) && \
    echo "=== finding llama-server ===" && \
    find . -name "llama-server" -type f 2>/dev/null | head -5 && \
    find . -name "llama-server" -type f -exec cp {} /build/llama-server \; || true

# Download the pre-converted 400MB GGUF
RUN python3 -c "from huggingface_hub import hf_hub_download; hf_hub_download('microsoft/bitnet-b1.58-2B-4T-gguf', 'ggml-model-i2_s.gguf', local_dir='/build/model')"

# Export artifacts
RUN mkdir -p /export/lib && \
    (cp /build/llama-server /export/ 2>/dev/null || \
     find . -name "llama-server" -type f -exec cp {} /export/ \;) && \
    find . -name "libllama.so*" -exec cp {} /export/lib/ \; && \
    find . -name "libggml.so*" -exec cp {} /export/lib/ \; && \
    find . -name "libggml-base.so*" -exec cp {} /export/lib/ \; && \
    find . -name "libggml-cpu.so*" -exec cp {} /export/lib/ \; && \
    ls -la /export/ /export/lib/ && \
    test -f /export/llama-server

FROM registry.access.redhat.com/ubi9/ubi-minimal:9.4

RUN microdnf install -y libstdc++ libgomp libomp && microdnf clean all

COPY --from=builder /export/llama-server /usr/local/bin/llama-server
COPY --from=builder /export/lib/ /usr/local/lib/
COPY --from=builder /build/model/ggml-model-i2_s.gguf /models/ggml-model-i2_s.gguf
ENV LD_LIBRARY_PATH=/usr/local/lib

USER 1001
EXPOSE 8080

ENTRYPOINT ["llama-server"]
CMD ["--model", "/models/ggml-model-i2_s.gguf", \
     "--host", "0.0.0.0", "--port", "8080", \
     "--ctx-size", "2048", "--threads", "16", \
     "--alias", "bitnet-2b4t"]
