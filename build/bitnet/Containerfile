# BitNet llama-server — native 1.58-bit ternary inference on CPU
# Patched from edge-ai-cpu-inference to relax torch version pin

FROM registry.access.redhat.com/ubi9/ubi:9.4 AS builder

RUN dnf install -y clang cmake make git python3 python3-pip && \
    dnf clean all

WORKDIR /build
RUN git clone --recursive https://github.com/microsoft/BitNet.git

WORKDIR /build/BitNet

# Relax torch version pin — upstream requires 2.11.0 which doesn't exist yet
RUN sed -i 's/torch==2\.11\.0/torch>=2.5.0/' requirements.txt && \
    pip3 install -r requirements.txt

# Pre-patch const-correctness bug in ternary kernel
RUN find . -name "*.cpp" -o -name "*.h" | \
    xargs grep -rl "int8_t \* y_col" 2>/dev/null | \
    xargs sed -i 's/int8_t \* y_col/const int8_t * y_col/g' 2>/dev/null; \
    echo "const patch applied"

# Build llama-server
RUN cmake -B build -DBITNET_X86_TL2=OFF \
    -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ \
    -DLLAMA_FATAL_WARNINGS=OFF 2>&1 && \
    cmake --build build --config Release -j$(nproc) 2>&1

# Download the pre-converted 400MB GGUF
RUN huggingface-cli download microsoft/bitnet-b1.58-2B-4T-gguf \
    ggml-model-i2_s.gguf --local-dir /build/model

# Export artifacts
RUN mkdir -p /export/lib && \
    cp build/bin/llama-server /export/ && \
    find build/ -name "libllama.so" -exec cp {} /export/lib/ \; && \
    find build/ -name "libggml.so" -exec cp {} /export/lib/ \; && \
    find build/ -name "libggml-base.so" -exec cp {} /export/lib/ \; && \
    find build/ -name "libggml-cpu.so" -exec cp {} /export/lib/ \; && \
    ls -la /export/ /export/lib/

FROM registry.access.redhat.com/ubi9/ubi-minimal:9.4

RUN microdnf install -y libstdc++ libgomp libomp && microdnf clean all

COPY --from=builder /export/llama-server /usr/local/bin/llama-server
COPY --from=builder /export/lib/ /usr/local/lib/
COPY --from=builder /build/model/ggml-model-i2_s.gguf /models/ggml-model-i2_s.gguf
ENV LD_LIBRARY_PATH=/usr/local/lib

USER 1001
EXPOSE 8080

ENTRYPOINT ["llama-server"]
CMD ["--model", "/models/ggml-model-i2_s.gguf", \
     "--host", "0.0.0.0", "--port", "8080", \
     "--ctx-size", "2048", "--threads", "16", \
     "--alias", "bitnet-2b4t"]
