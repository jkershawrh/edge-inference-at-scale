# Edge Inference at Scale — Environment Configuration

# Node identity
NODE_ID=edge-node-001

# SMS mode: "sim" (web simulator) or "twilio" (real SMS)
SMS_MODE=sim

# Twilio (only needed when SMS_MODE=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# BitNet inference server
BITNET_SERVER_URL=http://bitnet-server:8080
MODEL_NAME=bitnet-2b4t

# RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_HOST=chromadb
CHROMA_PORT=8000
SUMMIT_DATA_DIR=/data/summit_connect

# Redis (message queue)
REDIS_URL=redis://redis:6379/0

# Service URLs (internal)
SMS_GATEWAY_URL=http://sms-gateway:8001
MESSAGE_ROUTER_URL=http://message-router:8002
LLM_INFERENCE_URL=http://llm-inference:8003
RAG_SERVICE_URL=http://rag-service:8004
PRIVACY_FILTER_URL=http://privacy-filter:8005

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100
